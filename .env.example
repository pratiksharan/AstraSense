# AI provider: auto (infer from key), xai, or grok
AI_PROVIDER=auto

# API key for selected provider (use either variable name)
GROQ_API_KEY=
# GROK_API_KEY=

# Optional model override (preferred provider-specific model ID)
# GROQ_MODEL is commonly used for Groq deployments.
GROQ_MODEL=

# Optional generic model override (takes highest precedence if set)
AI_MODEL=

# Render injects PORT automatically; keep this for local fallback only.
PORT=8787
